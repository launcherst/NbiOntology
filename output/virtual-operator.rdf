<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xml:base="http://example.org/ontology/virtual-operator/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:ont="http://example.org/ontology/virtual-operator/">

    <owl:Ontology rdf:about="http://example.org/ontology/virtual-operator/">
        <rdfs:label>Virtual Operator</rdfs:label>
        <rdfs:comment>A sample ontology representing a modern coffee shop chain with suppliers, products, stores, customers, and orders.</rdfs:comment>
    </owl:Ontology>

    <!-- ===================== -->
    <!-- Entity Types (Classes) -->
    <!-- ===================== -->

    <owl:Class rdf:about="http://example.org/ontology/virtual-operator/Customer">
        <rdfs:label>NE</rdfs:label>
        <rdfs:comment>Network Element</rdfs:comment>
        <ont:icon>📦</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/virtual-operator/Order">
        <rdfs:label>Card</rdfs:label>
        <rdfs:comment>card</rdfs:comment>
        <ont:icon>💳</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/virtual-operator/Product">
        <rdfs:label>Port</rdfs:label>
        <rdfs:comment>port</rdfs:comment>
        <ont:icon>🎯</ont:icon>
        <ont:color>#5C2D91</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/virtual-operator/Store">
        <rdfs:label>TopoLink</rdfs:label>
        <rdfs:comment>topo link</rdfs:comment>
        <ont:icon>🔗</ont:icon>
        <ont:color>#FFB900</ont:color>
    </owl:Class>

    <!-- ================ -->
    <!-- Data Properties -->
    <!-- ================ -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/virtual-operator/customer_rmUID">
        <rdfs:label>rmUID</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/virtual-operator/Customer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Unique customer identifier</rdfs:comment>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/virtual-operator/customer_nativeName">
        <rdfs:label>nativeName</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/virtual-operator/Customer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Full name of the customer</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/virtual-operator/customer_location">
        <rdfs:label>location</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/virtual-operator/Customer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Contact email address</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/virtual-operator/customer_productName">
        <rdfs:label>productName</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/virtual-operator/Customer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Loyalty program tier</rdfs:comment>
        <ont:enumValues>Bronze,Silver,Gold,Platinum</ont:enumValues>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/virtual-operator/customer_vendor">
        <rdfs:label>vendor</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/virtual-operator/Customer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Date the customer joined</rdfs:comment>
        <ont:propertyType>enum</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/virtual-operator/customer_role">
        <rdfs:label>role</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/virtual-operator/Customer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Lifetime spend amount</rdfs:comment>
        <ont:unit>USD</ont:unit>
        <ont:propertyType>enum</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/virtual-operator/order_rmUID">
        <rdfs:label>rmUID</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/virtual-operator/Order"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Unique order identifier</rdfs:comment>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/virtual-operator/order_nativeName">
        <rdfs:label>nativeName</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/virtual-operator/Order"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>When the order was placed</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/virtual-operator/product_rmUID">
        <rdfs:label>rmUID</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/virtual-operator/Product"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Unique product identifier</rdfs:comment>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/virtual-operator/product_nativeName">
        <rdfs:label>nativeName</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/virtual-operator/Product"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Product name</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/virtual-operator/product_portNo">
        <rdfs:label>portNo</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/virtual-operator/Product"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>Product category</rdfs:comment>
        <ont:enumValues>Espresso,Brewed,Cold Brew,Tea,Food,Merchandise</ont:enumValues>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/virtual-operator/product_portRate">
        <rdfs:label>portRate</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/virtual-operator/Product"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Unit price</rdfs:comment>
        <ont:unit>USD</ont:unit>
        <ont:propertyType>enum</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/virtual-operator/store_rmUID">
        <rdfs:label>rmUID</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/virtual-operator/Store"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Unique store identifier</rdfs:comment>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/virtual-operator/store_nativeName">
        <rdfs:label>nativeName</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/virtual-operator/Store"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Store name</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- ================== -->
    <!-- Object Properties -->
    <!-- ================== -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/virtual-operator/rel-relates-to-2">
        <rdfs:label>connects_to</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/virtual-operator/Store"/>
        <rdfs:range rdf:resource="http://example.org/ontology/virtual-operator/Product"/>
        <rdfs:comment>a TopoLink connects to two ports</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>store</ont:fromEntityId>
        <ont:toEntityId>product</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/virtual-operator/customer_places_order">
        <rdfs:label>has</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/virtual-operator/Customer"/>
        <rdfs:range rdf:resource="http://example.org/ontology/virtual-operator/Order"/>
        <rdfs:comment>A NE has one or more cards</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>customer</ont:fromEntityId>
        <ont:toEntityId>order</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/virtual-operator/order_contains_product">
        <rdfs:label>contains</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/virtual-operator/Order"/>
        <rdfs:range rdf:resource="http://example.org/ontology/virtual-operator/Product"/>
        <rdfs:comment>A card contains one or more ports</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>order</ont:fromEntityId>
        <ont:toEntityId>product</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/virtual-operator/order_contains_product_quantity">
        <rdfs:label>quantity</rdfs:label>
        <rdfs:comment>Relationship attribute for contains</rdfs:comment>
        <ont:relationshipAttributeOf>order_contains_product</ont:relationshipAttributeOf>
        <ont:attributeType>integer</ont:attributeType>
    </owl:DatatypeProperty>

</rdf:RDF>
