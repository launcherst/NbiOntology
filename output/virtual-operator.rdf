<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xml:base="http://example.org/ontology/virtual-network/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:ont="http://example.org/ontology/virtual-network/">

    <owl:Ontology rdf:about="http://example.org/ontology/virtual-network/">
        <rdfs:label>Virtual Network</rdfs:label>
        <rdfs:comment>A sample ontology representing a virtual network with NEs, Cards, Ports, TopoLinks.</rdfs:comment>
    </owl:Ontology>

    <!-- ===================== -->
    <!-- Entity Types (Classes) -->
    <!-- ===================== -->

    <owl:Class rdf:about="http://example.org/ontology/virtual-network/NE">
        <rdfs:label>NE</rdfs:label>
        <rdfs:comment>Network Element</rdfs:comment>
        <ont:icon>📦</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/virtual-network/Card">
        <rdfs:label>Card</rdfs:label>
        <rdfs:comment>card</rdfs:comment>
        <ont:icon>💳</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/virtual-network/Port">
        <rdfs:label>Port</rdfs:label>
        <rdfs:comment>port</rdfs:comment>
        <ont:icon>🎯</ont:icon>
        <ont:color>#5C2D91</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/virtual-network/TopoLink">
        <rdfs:label>TopoLink</rdfs:label>
        <rdfs:comment>topo link</rdfs:comment>
        <ont:icon>🔗</ont:icon>
        <ont:color>#FFB900</ont:color>
    </owl:Class>

    <!-- ================ -->
    <!-- Data Properties -->
    <!-- ================ -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/virtual-network/NE_nativeName">
        <rdfs:label>nativeName</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/virtual-network/NE"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>native name showed in EMS</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/virtual-network/NE_location">
        <rdfs:label>location</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/virtual-network/NE"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>coordinate in form of {&apos;longitude&apos;: 123,&apos;latitude&apos;: 123}</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/virtual-network/NE_productName">
        <rdfs:label>productName</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/virtual-network/NE"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>product name such as OSN 9800</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/virtual-network/NE_vendor">
        <rdfs:label>vendor</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/virtual-network/NE"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Date the customer joined</rdfs:comment>
        <ont:enumValues>HW,ZTE,FH</ont:enumValues>
        <ont:propertyType>enum</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/virtual-network/NE_role">
        <rdfs:label>role</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/virtual-network/NE"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>NE role in OTN</rdfs:comment>
        <ont:enumValues>OTN,OLA,OADM,OXC</ont:enumValues>
        <ont:propertyType>enum</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/virtual-network/Card_rmUID">
        <rdfs:label>rmUID</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/virtual-network/Card"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Unique order identifier</rdfs:comment>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/virtual-network/Card_nativeName">
        <rdfs:label>nativeName</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/virtual-network/Card"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>When the order was placed</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/virtual-network/Port_rmUID">
        <rdfs:label>rmUID</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/virtual-network/Port"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Unique product identifier</rdfs:comment>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/virtual-network/Port_nativeName">
        <rdfs:label>nativeName</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/virtual-network/Port"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Product name</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/virtual-network/Port_portNo">
        <rdfs:label>portNo</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/virtual-network/Port"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>Product number in the card</rdfs:comment>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/virtual-network/Port_portRate">
        <rdfs:label>portRate</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/virtual-network/Port"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>bandwidth</rdfs:comment>
        <ont:unit>Gbps</ont:unit>
        <ont:enumValues>1,10,100,200,400</ont:enumValues>
        <ont:propertyType>enum</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/virtual-network/TopoLink_rmUID">
        <rdfs:label>rmUID</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/virtual-network/TopoLink"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Unique store identifier</rdfs:comment>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/virtual-network/TopoLink_nativeName">
        <rdfs:label>nativeName</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/virtual-network/TopoLink"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>TopoLink name</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- ================== -->
    <!-- Object Properties -->
    <!-- ================== -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/virtual-network/rel-relates-to-2">
        <rdfs:label>connects</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/virtual-network/TopoLink"/>
        <rdfs:range rdf:resource="http://example.org/ontology/virtual-network/Port"/>
        <rdfs:comment>a TopoLink connects two ports</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>topoLink</ont:fromEntityId>
        <ont:toEntityId>port</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/virtual-network/ne_has_card">
        <rdfs:label>has</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/virtual-network/NE"/>
        <rdfs:range rdf:resource="http://example.org/ontology/virtual-network/Card"/>
        <rdfs:comment>A NE has one or more cards</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>nE</ont:fromEntityId>
        <ont:toEntityId>card</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/virtual-network/card_contains_port">
        <rdfs:label>contains</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/virtual-network/Card"/>
        <rdfs:range rdf:resource="http://example.org/ontology/virtual-network/Port"/>
        <rdfs:comment>A card contains one or more ports</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>card</ont:fromEntityId>
        <ont:toEntityId>port</ont:toEntityId>
    </owl:ObjectProperty>

</rdf:RDF>
