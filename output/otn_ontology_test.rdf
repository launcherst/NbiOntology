<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xml:base="http://example.org/ontology/otn-ontology/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:ont="http://example.org/ontology/otn-ontology#">

    <owl:Ontology rdf:about="http://example.org/ontology/otn-ontology/">
        <rdfs:label>otn ontology</rdfs:label>
        <rdfs:comment>Generated ontology for otn resources</rdfs:comment>
    </owl:Ontology>

    <!-- ====================== -->
    <!-- Entity Types (Classes) -->
    <!-- ====================== -->

    <owl:Class rdf:about="http://example.org/ontology/otn-ontology#NE">
        <rdfs:label>NE</rdfs:label>
        <rdfs:name>网元</rdfs:name>
        <ont:shortName>NEL</ont:shortName>
        <rdfs:comment>otn资源类: 网元</rdfs:comment>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/ontology/otn-ontology#Card">
        <rdfs:label>Card</rdfs:label>
        <rdfs:name>板卡</rdfs:name>
        <ont:shortName>CRD</ont:shortName>
        <rdfs:comment>otn资源类: 板卡</rdfs:comment>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/ontology/otn-ontology#Port">
        <rdfs:label>Port</rdfs:label>
        <rdfs:name>端口</rdfs:name>
        <ont:shortName>PRT</ont:shortName>
        <rdfs:comment>otn资源类: 端口</rdfs:comment>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/ontology/otn-ontology#TopoLink">
        <rdfs:label>TopoLink</rdfs:label>
        <rdfs:name>拓扑</rdfs:name>
        <ont:shortName>TPL</ont:shortName>
        <rdfs:comment>otn资源类: 拓扑</rdfs:comment>
    </owl:Class>

    <!-- =============== -->
    <!-- Data Properties -->
    <!-- =============== -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/otn-ontology#NE_rmUID">
        <rdfs:label>NE_rmUID</rdfs:label>
        <rdfs:name>网元rmUID</rdfs:name>
        <rdfs:domain rdf:resource="http://example.org/ontology/otn-ontology#NE"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment></rdfs:comment>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/otn-ontology#NE_nativeName">
        <rdfs:label>NE_nativeName</rdfs:label>
        <rdfs:name>本地名称</rdfs:name>
        <rdfs:domain rdf:resource="http://example.org/ontology/otn-ontology#NE"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment></rdfs:comment>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/otn-ontology#NE_location">
        <rdfs:label>NE_location</rdfs:label>
        <rdfs:name>物理位置</rdfs:name>
        <rdfs:domain rdf:resource="http://example.org/ontology/otn-ontology#NE"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment></rdfs:comment>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/otn-ontology#NE_productName">
        <rdfs:label>NE_productName</rdfs:label>
        <rdfs:name>设备型号</rdfs:name>
        <rdfs:domain rdf:resource="http://example.org/ontology/otn-ontology#NE"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment></rdfs:comment>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/otn-ontology#NE_vendor">
        <rdfs:label>NE_vendor</rdfs:label>
        <rdfs:name>设备供应商</rdfs:name>
        <rdfs:domain rdf:resource="http://example.org/ontology/otn-ontology#NE"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment></rdfs:comment>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/otn-ontology#NE_role">
        <rdfs:label>NE_role</rdfs:label>
        <rdfs:name>角色</rdfs:name>
        <rdfs:domain rdf:resource="http://example.org/ontology/otn-ontology#NE"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#enum"/>
        <rdfs:comment></rdfs:comment>
        <ont:enumValues>OTM,OLA,OADM,OXC</ont:enumValues>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/otn-ontology#Card_rmUID">
        <rdfs:label>Card_rmUID</rdfs:label>
        <rdfs:name>板卡rmUID</rdfs:name>
        <rdfs:domain rdf:resource="http://example.org/ontology/otn-ontology#Card"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment></rdfs:comment>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/otn-ontology#Card_nermUID">
        <rdfs:label>Card_nermUID</rdfs:label>
        <rdfs:name>所属网元rmUID</rdfs:name>
        <rdfs:domain rdf:resource="http://example.org/ontology/otn-ontology#Card"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment></rdfs:comment>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/otn-ontology#Card_nativeName">
        <rdfs:label>Card_nativeName</rdfs:label>
        <rdfs:name>本地名称</rdfs:name>
        <rdfs:domain rdf:resource="http://example.org/ontology/otn-ontology#Card"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment></rdfs:comment>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/otn-ontology#Port_rmUID">
        <rdfs:label>Port_rmUID</rdfs:label>
        <rdfs:name>端口rmUID</rdfs:name>
        <rdfs:domain rdf:resource="http://example.org/ontology/otn-ontology#Port"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment></rdfs:comment>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/otn-ontology#Port_cardrmUID">
        <rdfs:label>Port_cardrmUID</rdfs:label>
        <rdfs:name>所属板卡rmUID</rdfs:name>
        <rdfs:domain rdf:resource="http://example.org/ontology/otn-ontology#Port"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment></rdfs:comment>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/otn-ontology#Port_portNo">
        <rdfs:label>Port_portNo</rdfs:label>
        <rdfs:name>端口序号</rdfs:name>
        <rdfs:domain rdf:resource="http://example.org/ontology/otn-ontology#Port"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment></rdfs:comment>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/otn-ontology#Port_nativeName">
        <rdfs:label>Port_nativeName</rdfs:label>
        <rdfs:name>本地名称</rdfs:name>
        <rdfs:domain rdf:resource="http://example.org/ontology/otn-ontology#Port"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment></rdfs:comment>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/otn-ontology#Port_portRate">
        <rdfs:label>Port_portRate</rdfs:label>
        <rdfs:name>端口速率</rdfs:name>
        <rdfs:domain rdf:resource="http://example.org/ontology/otn-ontology#Port"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#enum"/>
        <rdfs:comment></rdfs:comment>
        <ont:enumValues>10G,10GE,40G,40GE,100G,100GE,200G,200GE,300G,400G,400GE,nan,Other</ont:enumValues>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/otn-ontology#TopoLink_rmUID">
        <rdfs:label>TopoLink_rmUID</rdfs:label>
        <rdfs:name>拓扑连接rmUID</rdfs:name>
        <rdfs:domain rdf:resource="http://example.org/ontology/otn-ontology#TopoLink"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment></rdfs:comment>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/otn-ontology#TopoLink_nativeName">
        <rdfs:label>TopoLink_nativeName</rdfs:label>
        <rdfs:name>本地名称</rdfs:name>
        <rdfs:domain rdf:resource="http://example.org/ontology/otn-ontology#TopoLink"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment></rdfs:comment>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/otn-ontology#TopoLink_aEndNermUID">
        <rdfs:label>TopoLink_aEndNermUID</rdfs:label>
        <rdfs:name>连接起点网元rmUID</rdfs:name>
        <rdfs:domain rdf:resource="http://example.org/ontology/otn-ontology#TopoLink"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment></rdfs:comment>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/otn-ontology#TopoLink_zEndNermUID">
        <rdfs:label>TopoLink_zEndNermUID</rdfs:label>
        <rdfs:name>连接终点网元rmUID</rdfs:name>
        <rdfs:domain rdf:resource="http://example.org/ontology/otn-ontology#TopoLink"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment></rdfs:comment>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/otn-ontology#TopoLink_aEndPortrmUID">
        <rdfs:label>TopoLink_aEndPortrmUID</rdfs:label>
        <rdfs:name>连接起点端口rmUID</rdfs:name>
        <rdfs:domain rdf:resource="http://example.org/ontology/otn-ontology#TopoLink"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment></rdfs:comment>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/otn-ontology#TopoLink_zEndPortrmUID">
        <rdfs:label>TopoLink_zEndPortrmUID</rdfs:label>
        <rdfs:name>连接终点端口rmUID</rdfs:name>
        <rdfs:domain rdf:resource="http://example.org/ontology/otn-ontology#TopoLink"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment></rdfs:comment>
    </owl:DatatypeProperty>

    <!-- ================= -->
    <!-- Object Properties -->
    <!-- ================= -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/otn-ontology#NE_has_Card">
        <rdfs:label>NE_has_Card</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/otn-ontology#NE"/>
        <rdfs:range rdf:resource="http://example.org/ontology/otn-ontology#Card"/>
        <rdfs:comment>NE has one or more Cards</rdfs:comment>
        <ont:cardinality>1..*</ont:cardinality>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/ontology/otn-ontology#Card_has_Port">
        <rdfs:label>Card_has_Port</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/otn-ontology#Card"/>
        <rdfs:range rdf:resource="http://example.org/ontology/otn-ontology#Port"/>
        <rdfs:comment>Card has one or more Ports</rdfs:comment>
        <ont:cardinality>1..*</ont:cardinality>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/ontology/otn-ontology#TopoLink_connects_Port">
        <rdfs:label>TopoLink_connects_Port</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/otn-ontology#TopoLink"/>
        <rdfs:range rdf:resource="http://example.org/ontology/otn-ontology#Port"/>
        <rdfs:comment>TopoLink connects to two Ports</rdfs:comment>
        <ont:cardinality>2</ont:cardinality>
    </owl:ObjectProperty>
</rdf:RDF>
